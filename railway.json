{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "sh -c 'cd backend && npm install --production'"
  },
  "deploy": {
    "startCommand": "sh -c 'cd backend && node server.js'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

